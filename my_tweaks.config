# =========================
# 🔥 CORE PERFORMANCE TUNING
# =========================
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_INFO_DWARF4=n
CONFIG_DEBUG_INFO_BTF=n
CONFIG_KPROBES=y          # ← WAJIB y untuk KSU
CONFIG_OPROFILE=n
CONFIG_KALLSYMS_ALL=n
CONFIG_DEBUG_FS=n
CONFIG_FTRACE=n
CONFIG_FUNCTION_TRACER=n
CONFIG_IRQSOFF_TRACER=n

# =========================
# ❌ SANITIZERS OFF
# =========================
CONFIG_KASAN=n
CONFIG_KCSAN=n
CONFIG_UBSAN=n

# =========================
# ⚙️ SCHEDULER
# =========================
CONFIG_SCHED_AUTOGROUP=y
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_BUCKETS_COUNT=5
CONFIG_PREEMPT=y

# =========================
# 🚀 CPU GOVERNOR
# =========================
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# =========================
# 🔋 POWER
# =========================
CONFIG_NO_HZ_IDLE=y
CONFIG_NO_HZ_FULL=n
CONFIG_HZ_300=y
CONFIG_ENERGY_MODEL=y

# =========================
# 🚀 COMPILER
# =========================
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE_O3=n
CONFIG_LTO_CLANG=n        # ← OFF dulu, sering bikin masalah modpost
CONFIG_THINLTO=n          # ← OFF dulu

# =========================
# 🌐 NETWORK
# =========================
CONFIG_TCP_CONG_BBR=y

# =========================
# ⚠️ SAFETY
# =========================
CONFIG_ARM64=y
CONFIG_SMP=y

# =========================
# KSU
# =========================
CONFIG_KSU=y
CONFIG_KSU_NEXT=y
CONFIG_KSU_WITH_KPROBES=y
