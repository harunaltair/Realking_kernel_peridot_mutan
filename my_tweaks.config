# =========================
# 🔥 CORE PERFORMANCE TUNING
# =========================

# Disable ALL debug (impact besar)
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_INFO_DWARF4=n
CONFIG_DEBUG_INFO_BTF=n
CONFIG_KPROBES=n
CONFIG_OPROFILE=n
CONFIG_KALLSYMS_ALL=n
CONFIG_DEBUG_FS=n
CONFIG_FTRACE=n
CONFIG_FUNCTION_TRACER=n
CONFIG_IRQSOFF_TRACER=n

# Disable sanitizers (WAJIB)
CONFIG_KASAN=n
CONFIG_KCSAN=n
CONFIG_UBSAN=n

# =========================
# ⚙️ SCHEDULER (ADAPTIVE)
# =========================

CONFIG_SCHED_AUTOGROUP=y
CONFIG_UCLAMP_TASK=y
CONFIG_UCLAMP_BUCKETS_COUNT=5

# Preempt untuk responsiveness
CONFIG_PREEMPT=y

# =========================
# 🚀 CPU GOVERNOR
# =========================

CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y

# =========================
# 🔋 POWER EFFICIENCY
# =========================

# Idle power saving
CONFIG_NO_HZ_IDLE=y
CONFIG_NO_HZ_FULL=n

# Balance latency & battery
CONFIG_HZ_300=y

# Energy aware scheduling
CONFIG_ENERGY_MODEL=y

# =========================
# 🚀 COMPILER OPTIMIZATION
# =========================

# Stabil (jangan O3 dulu)
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE=y
CONFIG_CC_OPTIMIZE_FOR_PERFORMANCE_O3=n

# LTO (impact besar)
CONFIG_LTO_CLANG=y
CONFIG_THINLTO=y

# =========================
# 🌐 NETWORK (optional boost)
# =========================

CONFIG_TCP_CONG_BBR=y

# =========================
# ⚠️ SAFETY (JANGAN DIHAPUS)
# =========================

CONFIG_ARM64=y
CONFIG_SMP=y

CONFIG_KSU=y
CONFIG_KSU_NEXT=y
CONFIG_KSU_WITH_KPROBES=y
