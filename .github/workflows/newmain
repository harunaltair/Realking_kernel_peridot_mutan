name: Mutan Kernel Auto Pipeline (Peridot)

on:
  push:
    branches: [ main ]
    paths:
      - 'arch/**'
      - 'drivers/**'
      - 'include/**'
      - 'kernel/**'
      - 'my_tweaks.config'
      - 'hyperos_defconfig'
      - '.github/workflows/**'
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: write

    steps:
      - name: Checkout Source
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          submodules: false

      - name: Install Dependencies
        run: |
          sudo apt update
          sudo apt install -y bc bison build-essential flex git curl zip \
          libssl-dev libncurses-dev libelf-dev pahole ccache device-tree-compiler

      - name: Setup Clang 20
        run: |
          mkdir clang && cd clang
          curl -LO https://github.com/ZyCromerZ/Clang/releases/download/20.0.0git-20250129-release/Clang-20.0.0git-20250129.tar.gz
          tar -xf *.tar.gz
          echo "$(pwd)/bin" >> $GITHUB_PATH

      - name: Setup ccache
        run: |
          echo "CCACHE_DIR=$HOME/.ccache" >> $GITHUB_ENV
          echo "CCACHE_MAXSIZE=5G" >> $GITHUB_ENV

      - name: Clean KSU References
        run: |
          sed -i '/kernelsu/Id' drivers/Kconfig || true
          sed -i '/kernelsu/Id' drivers/Makefile || true
          rm -rf drivers/kernelsu KernelSU-Next || true

      - name: Setup KernelSU Next
        run: |
          git clone --depth=1 https://github.com/KernelSU-Next/KernelSU-Next.git -b dev KernelSU-Next
          rm -rf KernelSU-Next/.git
          cp -r KernelSU-Next/kernel drivers/kernelsu

          echo 'source "drivers/kernelsu/Kconfig"' >> drivers/Kconfig
          echo 'obj-$(CONFIG_KSU) += kernelsu/' >> drivers/Makefile

          ls drivers/kernelsu/Kconfig || (echo "KSU FAILED!" && exit 1)

          echo "KSU_VERSION=$(grep '^KERNELSU_VERSION' drivers/kernelsu/Makefile | cut -d= -f2 | tr -d ' ')" >> $GITHUB_ENV

      - name: Prepare Config
        run: |
          export ARCH=arm64
          export SUBARCH=arm64

          rm -f .config
          rm -rf include/config
          rm -rf arch/arm64/include/generated

          git add -A
          git -c user.email="ci@build" -c user.name="CI" commit -m "ci: inject KSU Next" || true

          mkdir -p out
          make O=out peridot_defconfig

          scripts/kconfig/merge_config.sh -m out/.config hyperos_defconfig
          scripts/kconfig/merge_config.sh -m out/.config my_tweaks.config

          rm -f .config
          rm -rf include/config
          rm -rf arch/arm64/include/generated

          make O=out olddefconfig

      - name: Build Kernel
        run: |
          export ARCH=arm64
          export SUBARCH=arm64
          export KBUILD_BUILD_USER="Mutan"
          export KBUILD_BUILD_HOST="AutoPipeline"
          export CC="ccache clang"

          make -j$(nproc --all) O=out \
            LLVM=1 \
            LLVM_IAS=1 \
            CLANG_TRIPLE=aarch64-linux-gnu- \
            CROSS_COMPILE=aarch64-linux-android- \
            KCFLAGS="-O2 -pipe -fno-stack-protector"

      - name: Build DTBs
        run: |
          export ARCH=arm64
          export SUBARCH=arm64
          make -j$(nproc --all) O=out dtbs

      - name: Verify Image.gz-dtb
        run: |
          echo "Checking if peridot DTB exists in Image.gz-dtb..."
          if strings out/arch/arm64/boot/Image.gz-dtb | grep -iq peridot; then
            echo "✅ DTB peridot included in Image.gz-dtb"
            echo "DTB_STATUS=included" >> $GITHUB_ENV
          else
            echo "⚠️ WARNING: DTB peridot NOT found in Image.gz-dtb"
            echo "DTB_STATUS=missing" >> $GITHUB_ENV
          fi

      - name: Package AnyKernel3
        run: |
          cp -r anykernel/* .   # pakai folder anykernel di repo sendiri

          sed -i 's/kernel.string=.*/kernel.string=Mutan Kernel (Peridot) KSUNext-${{ env.KSU_VERSION }}/g' anykernel.sh
          sed -i 's/device.name1=.*/device.name1=peridot/g' anykernel.sh

          if [ ! -f ../out/arch/arm64/boot/Image.gz ]; then
            echo "Kernel Image.gz not found!"
            exit 1
          fi
          cp ../out/arch/arm64/boot/Image.gz .

          if [ -f ../out/arch/arm64/boot/dtbo.img ]; then
            cp ../out/arch/arm64/boot/dtbo.img .
          else
            echo "Skipping dtbo.img"
          fi

          ZIP_NAME=MutanKernel-KSUNext-$(date +%Y%m%d-%H%M).zip
          zip -r9 ../$ZIP_NAME *
          echo "ZIP_NAME=$ZIP_NAME" >> $GITHUB_ENV

      - name: Set Tag
        run: echo "TAG_NAME=auto-$(date +%Y%m%d-%H%M)" >> $GITHUB_ENV

      - name: Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ env.TAG_NAME }}
          name: "Mutan Kernel | KSU Next v${{ env.KSU_VERSION }}"
          body: |
            ## Mutan Kernel Auto Build

            🧠 Commit: ${{ github.sha }}

            ✅ KernelSU Next v${{ env.KSU_VERSION }}
            ✅ Auto Merge HyperOS Config
            ✅ Auto Inject Tweaks
            ✅ Balanced Performance Kernel

            ### Device
            - Poco F6 (Peridot)
            - DTB Status: ${{ env.DTB_STATUS }}
          files: ${{ env.ZIP_NAME }}
